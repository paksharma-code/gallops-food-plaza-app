{
  "expo": {
    "name": "Gallops Food Plaza",
    "slug": "gallops-food-plaza",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gallops",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "primaryColor": "#2C1E7A",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gallops.foodplaza",
      "buildNumber": "1",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload plaza & outlet photos from your gallery.",
        "NSCameraUsageDescription": "Take quick photos for new plazas & outlets.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.gallops.foodplaza",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2C1E7A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Gallops Food Plaza",
      "shortName": "Gallops",
      "themeColor": "#2C1E7A",
      "backgroundColor": "#2C1E7A"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 260,
          "resizeMode": "contain",
          "backgroundColor": "#2C1E7A"
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
